generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── Users ─────────────────────────────────────────────────────────

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String
  name             String   @default("")
  plan             String   @default("free")   // mirrors active subscription plan slug
  status           String   @default("active")
  isAdmin          Boolean  @default(false)
  stripeCustomerId String?  @unique            // Stripe customer ID, set on first checkout
  createdAt        DateTime @default(now())

  @@map("users")
}

model Device {
  id          String @id @default(uuid())
  userId      String
  fingerprint String
  name        String @default("Device")
  lastSeen    String @default("")

  @@unique([userId, fingerprint])
  @@map("devices")
}

// ── Subscription Plans ────────────────────────────────────────────

model SubscriptionPlan {
  id                   String   @id
  name                 String
  slug                 String   @unique
  price                Float    @default(0)    // monthly price USD
  yearlyPrice          Float    @default(0)    // yearly price USD
  features             Json     @default("[]")
  type                 String   @default("free")
  maxDevices           Int      @default(1)
  maxProducts          Int      @default(50)
  maxCustomers         Int      @default(5)
  stripePriceIdMonthly String?                 // Set in Stripe Dashboard → Products
  stripePriceIdYearly  String?
  createdAt            DateTime @default(now())

  subscriptions UserSubscription[]

  @@map("subscription_plans")
}

// ── Subscriptions ─────────────────────────────────────────────────

model UserSubscription {
  id                   String    @id @default(uuid())
  userId               String    @unique
  planId               String
  stripeCustomerId     String?
  stripeSubscriptionId String?   @unique
  stripeSessionId      String?
  planName             String    @default("")
  billingCycle         String    @default("monthly")  // monthly | yearly
  status               String    @default("active")   // active | cancelled | past_due | expired
  startDate            DateTime  @default(now())
  endDate              DateTime?
  createdAt            DateTime  @default(now())

  plan     SubscriptionPlan @relation(fields: [planId], references: [id])
  payments Payment[]

  @@map("user_subscriptions")
}

// ── Payments ──────────────────────────────────────────────────────

model Payment {
  id                    String    @id @default(uuid())
  userId                String    @unique   // one payment record per user at all times
  subscriptionId        String?
  amount                Float
  currency              String    @default("usd")
  paymentStatus         String    @default("pending")  // pending | completed | failed
  stripePaymentIntentId String?
  stripeInvoiceId       String?
  createdAt             DateTime  @default(now())

  subscription UserSubscription? @relation(fields: [subscriptionId], references: [id])

  @@map("payments")
}

// ── POS Data ──────────────────────────────────────────────────────

model Product {
  id        String  @id @default(uuid())
  userId    String  @default("")
  name      String
  sku       String
  barcode   String  @default("")
  category  String  @default("Uncategorized")
  sellPrice Float
  buyPrice  Float   @default(0)
  stock     Int     @default(0)
  imageUrl  String  @default("")
  taxable   Boolean @default(false)

  @@unique([userId, sku])
  @@map("products")
}

model Member {
  id              String @id @default(uuid())
  userId          String @default("")
  membershipId    String
  name            String
  phone           String
  email           String @default("")
  due             Float  @default(0)
  joinedAt        String @default("")
  purchaseHistory Json   @default("[]")

  @@unique([userId, phone])
  @@unique([userId, membershipId])
  @@map("members")
}

model Transaction {
  id            String  @id @default(uuid())
  userId        String  @default("")
  date          String
  items         Json
  subtotal      Float
  tax           Float
  discount      Float   @default(0)
  total         Float
  paymentMethod String
  memberId      String?
  status        String  @default("completed")
  returnedItems Json    @default("[]")

  @@map("transactions")
}

model Cart {
  cartId       String  @id
  userId       String  @default("")
  customerName String  @default("Walk-in")
  customerId   String?
  items        Json    @default("[]")
  discount     Float   @default(0)

  @@map("carts")
}

model Settings {
  id             String  @id
  userId         String  @default("")
  storeName      String  @default("ShopIQ Store")
  address        String  @default("")
  phone          String  @default("")
  email          String  @default("")
  taxRate        Float   @default(10)
  currency       String  @default("USD")
  currencySymbol String  @default("$")
  receiptHeader  String  @default("")
  receiptFooter  String  @default("")
  taxId          String  @default("")
  showLogo       Boolean @default(true)
  showTaxId      Boolean @default(false)
  theme          String  @default("light")

  @@map("settings")
}
